{
  "name": "gsclsp",
  "displayName": "GSC LSP - Language Support",
  "description": "Language Server for GSC Scripts",
  "version": "1.0.1",
  "icon": "logo.png",
  "publisher": "bbe-tools",
  "repository": {
    "type": "git",
    "url": "https://github.com/Lierrmm/GSCLSP"
  },
  "engines": {
    "vscode": "^1.80.0"
  },
  "categories": [
    "Programming Languages"
  ],
  "keywords": [
    "gsc",
    "lsp",
    "cod"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "gsclsp.browseDumpPath",
        "title": "GSC: Set Dump Folder Path"
      }
    ],
    "languages": [
      {
        "id": "gsc",
        "aliases": [
          "GSC",
          "gsc"
        ],
        "extensions": [
          ".gsc"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "gsc",
        "scopeName": "source.gsc",
        "path": "./syntaxes/gsc.tmLanguage.json"
      }
    ],
    "configuration": {
      "type": "object",
      "title": "GSC Intelligence",
      "properties": {
        "gsclsp.dumpPath": {
          "type": "string",
          "default": "",
          "description": "Path to your MW2 Game Dump folder for navigation."
        }
      }
    }
  },
  "scripts": {
    "build": "bun run build.ts",
    "package": "vsce package",
    "list": "vsce ls",
    "publish": "vsce publish"
  },
  "devDependencies": {
    "@types/node": "^25.3.3",
    "@types/vscode": "^1.75.0",
    "@vscode/vsce": "latest",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "vscode-languageclient": "^9.0.1"
  }
}
