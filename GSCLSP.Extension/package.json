{
  "name": "gsclsp",
  "displayName": "GSC LSP - Language Support",
  "description": "Language Server for GSC Scripts",
  "version": "1.0.3",
  "icon": "logo.png",
  "publisher": "bbe-tools",
  "repository": {
    "type": "git",
    "url": "https://github.com/Lierrmm/GSCLSP"
  },
  "engines": {
    "vscode": "^1.80.0"
  },
  "categories": [
    "Programming Languages"
  ],
  "keywords": [
    "gsc",
    "gsh",
    "lsp",
    "cod"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "gsclsp.browseDumpPath",
        "title": "GSC: Set Dump Folder Path"
      }
    ],
    "languages": [
      {
        "id": "gsc",
        "aliases": [
          "GSC",
          "gsc",
          "GSH",
          "gsh"
        ],
        "extensions": [
          ".gsc",
          ".gsh"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "gsc",
        "scopeName": "source.gsc",
        "path": "./syntaxes/gsc.tmLanguage.json"
      }
    ]
  },
  "scripts": {
    "build": "bun run build.ts",
    "package": "vsce package",
    "list": "vsce ls",
    "publish": "vsce publish"
  },
  "devDependencies": {
    "@types/node": "^25.3.3",
    "@types/vscode": "^1.75.0",
    "@vscode/vsce": "latest",
    "typescript": "^6.0.0"
  },
  "dependencies": {
    "vscode-languageclient": "^9.0.1"
  }
}
