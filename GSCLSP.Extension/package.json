{
  "name": "gsclsp",
  "displayName": "GSC LSP - Language Support",
  "version": "1.0.3",
  "description": "Language Server for GSC Scripts",
  "categories": [
    "Programming Languages"
  ],
  "keywords": [
    "cod",
    "gsc",
    "gsh",
    "lsp"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/Lierrmm/GSCLSP"
  },
  "publisher": "bbe-tools",
  "main": "./dist/extension.js",
  "scripts": {
    "build": "bun run build.ts",
    "package": "vsce package",
    "list": "vsce ls",
    "publish": "vsce publish",
    "lint": "oxlint",
    "fmt": "oxfmt"
  },
  "dependencies": {
    "vscode-languageclient": "^10.0.0"
  },
  "devDependencies": {
    "@types/node": "^24.13.2",
    "@types/vscode": "^1.75.0",
    "@vscode/vsce": "latest",
    "oxfmt": "^0.57.0",
    "oxlint": "^1.71.0",
    "typescript": "^6.0.0"
  },
  "contributes": {
    "configuration": {
      "type": "object",
      "title": "GSC LSP Configuration",
      "properties": {
        "gsclsp.trace.server": {
          "scope": "window",
          "type": "string",
          "enum": [
            "off",
            "messages",
            "verbose"
          ],
          "default": "verbose",
          "description": "Traces the communication between VS Code and the GSC language server."
        }
      }
    },
    "commands": [
      {
        "command": "gsclsp.browseDumpPath",
        "title": "GSC: Set Dump Folder Path"
      },
      {
        "command": "gsclsp.selectTargetGame",
        "title": "GSC: Select Target Game"
      }
    ],
    "languages": [
      {
        "id": "gsc",
        "aliases": [
          "GSC",
          "gsc",
          "GSH",
          "gsh"
        ],
        "extensions": [
          ".gsc",
          ".gsh"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "gsc",
        "scopeName": "source.gsc",
        "path": "./syntaxes/gsc.tmLanguage.json"
      }
    ]
  },
  "icon": "logo.png",
  "engines": {
    "vscode": "^1.80.0"
  }
}
